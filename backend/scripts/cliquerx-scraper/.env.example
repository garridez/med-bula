# Cliquerx API
CLIQUERX_BEARER=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJvcmciOiIwZGJmY2UxZC0zMWJiLTQwYjMtOTFhNy01YjNlYTBmOTFjZDkiLCJzdWIiOiIzZmE4NDkwYS0yMDU4LTQyNWUtOTVjOS1kMzNmZTQ2M2MyYzUiLCJleHAiOjE3Nzg3MDk0ODh9.P9q7-ljt8IYrKKOqOtPGM-5Q4mc5O3m7aGQxOxhLFes
CLIQUERX_BASE_URL=https://api.cliquerx.com.br

# Comportamento do scraper
# Concorrência de requests em paralelo (cuidado com rate limit; 3-5 é seguro)
SCRAPER_CONCURRENCY=4
# Delay entre requests do MESMO worker, em ms (jitter aplicado em cima)
SCRAPER_DELAY_MS=180
# Quando uma query retornar count >= este valor, expandimos o prefixo.
# Descoberto via probe: a API capa em ~40 (alguns casos retornam 44).
# Usar 40 garante que expandimos sempre que há chance de ter mais resultados.
SCRAPER_PAGE_LIMIT=40
# Profundidade máxima de prefixo (proteção contra loop). 4 cobre 99% dos casos.
SCRAPER_MAX_DEPTH=5
# Buscar posologias junto com medicamentos (true) ou só medicamentos (false)
SCRAPER_FETCH_POSOLOGIES=true

# Banco (usado só pelo import.mjs)
DB_HOST=localhost
DB_PORT=5432
DB_USER=med
DB_PASSWORD=changeme
DB_DATABASE=med_bula
